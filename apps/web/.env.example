CARMEN_API_KEY=<cloud-nnc-key>
BINARY_PATH=/home/azureuser/app/sdk_samples/samples/C++/build/05_cloud/cpp_sample_05_cloud

# Prefer the reverse-proxied /ws endpoint if you terminate TLS in front of the app.
NEXT_PUBLIC_WS_URL=wss://your-domain-or-ip/ws

# Direct fallback when exposing the WS server on port 3002 instead of proxying /ws:
# NEXT_PUBLIC_WS_URL=ws://your-domain-or-ip:3002
